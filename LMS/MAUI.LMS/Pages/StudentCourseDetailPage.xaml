<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI.LMS.Pages.StudentCourseDetailPage"
             Title="Course Detail">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Grade Banner (ISSUE-38) -->
            <Frame BackgroundColor="#1a237e" Padding="20" CornerRadius="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Current Grade"
                           TextColor="White"
                           FontSize="14"
                           HorizontalOptions="Center" />
                    <Label x:Name="LetterGradeLabel"
                           Text="N/A"
                           TextColor="White"
                           FontSize="64"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <Label x:Name="PercentageLabel"
                           Text=""
                           TextColor="#b0bec5"
                           FontSize="16"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Announcements (ISSUE-45) -->
            <VerticalStackLayout x:Name="AnnouncementsSection" Spacing="6" IsVisible="False">
                <Label Text="Announcements"
                       FontSize="18"
                       FontAttributes="Bold" />
                <CollectionView x:Name="AnnouncementsCollection" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,4" Padding="12" HasShadow="False" BackgroundColor="#fff8e1" BorderColor="#ffe082">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="15" />
                                    <Label Text="{Binding Body}" FontSize="14" />
                                    <Label Text="{Binding PostedDate, StringFormat='{0:MM/dd/yyyy}'}"
                                           FontSize="12" TextColor="Gray" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Modules Section -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Modules" FontSize="18" FontAttributes="Bold" />
                <CollectionView x:Name="ModulesCollection" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,4" Padding="12" HasShadow="False" BorderColor="LightGray">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" />
                                    <Label Text="{Binding ContentSummary}" FontSize="13" TextColor="Gray" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label x:Name="NoModulesLabel"
                       Text="No modules available."
                       TextColor="Gray"
                       IsVisible="False" />
            </VerticalStackLayout>

            <!-- Assignments Section -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Assignments" FontSize="18" FontAttributes="Bold" />
                <CollectionView x:Name="AssignmentsCollection" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,4" Padding="12" HasShadow="False" BorderColor="LightGray">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                    <VerticalStackLayout Grid.Column="0" Grid.RowSpan="3" Spacing="3">
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" />
                                            <Frame Padding="4,1" CornerRadius="4" BackgroundColor="#7b1fa2"
                                                   IsVisible="{Binding IsQuiz}" HasShadow="False">
                                                <Label Text="Quiz" TextColor="White" FontSize="11" />
                                            </Frame>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding DueDate, StringFormat='Due: {0:MM/dd/yyyy}'}"
                                               FontSize="13" TextColor="Gray" />
                                        <Label Text="{Binding GradeDisplay}" FontSize="13" TextColor="#1565c0" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1"
                                            Text="Submit"
                                            WidthRequest="80"
                                            VerticalOptions="Center"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnSubmitClicked" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label x:Name="NoAssignmentsLabel"
                       Text="No assignments available."
                       TextColor="Gray"
                       IsVisible="False" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
