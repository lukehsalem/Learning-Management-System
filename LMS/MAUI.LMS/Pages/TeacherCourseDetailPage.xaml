<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI.LMS.Pages.TeacherCourseDetailPage"
             Title="Course Management">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Course Header -->
            <Frame BackgroundColor="#1a237e" Padding="16" CornerRadius="10">
                <VerticalStackLayout Spacing="4">
                    <Label x:Name="CourseNameLabel" TextColor="White" FontSize="20" FontAttributes="Bold" />
                    <Label x:Name="CourseInfoLabel" TextColor="#b0bec5" FontSize="14" />
                </VerticalStackLayout>
            </Frame>

            <!-- Announcements (ISSUE-45) -->
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Announcements" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="+ Add" WidthRequest="70" Clicked="OnAddAnnouncementClicked" />
                </Grid>
                <CollectionView x:Name="AnnouncementsCollection" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,3" Padding="12" HasShadow="False" BackgroundColor="#fff8e1" BorderColor="#ffe082">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="15" />
                                        <Label Text="{Binding Body}" FontSize="13" />
                                        <Label Text="{Binding PostedDate, StringFormat='{0:MM/dd/yyyy}'}" FontSize="12" TextColor="Gray" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1"
                                            Text="Delete"
                                            WidthRequest="70"
                                            BackgroundColor="#c62828"
                                            VerticalOptions="Start"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnDeleteAnnouncementClicked" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label x:Name="NoAnnouncementsLabel" Text="No announcements." TextColor="Gray" IsVisible="False" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Roster (ISSUE-39) -->
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Label Grid.Column="0" Text="Roster" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="+ Enroll" WidthRequest="80" Margin="4,0" Clicked="OnEnrollStudentClicked" />
                    <Button Grid.Column="2" Text="Import" WidthRequest="75" Clicked="OnImportRosterClicked" />
                </Grid>
                <Button Text="Export Roster (CSV)" Clicked="OnExportRosterClicked" HorizontalOptions="Start" />
                <CollectionView x:Name="RosterCollection" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,3" Padding="12" HasShadow="False" BorderColor="LightGray">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" />
                                        <Label Text="{Binding Code}" FontSize="13" TextColor="Gray" />
                                        <Label Text="{Binding Classification}" FontSize="13" TextColor="Gray" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1"
                                            Text="Remove"
                                            WidthRequest="80"
                                            BackgroundColor="#c62828"
                                            VerticalOptions="Center"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnUnenrollStudentClicked" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label x:Name="NoRosterLabel" Text="No students enrolled." TextColor="Gray" IsVisible="False" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Assignments (ISSUE-41, 46) -->
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Label Grid.Column="0" Text="Assignments" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="+ Add" WidthRequest="70" Margin="4,0" Clicked="OnAddAssignmentClicked" />
                    <Button Grid.Column="2" Text="Copy" WidthRequest="70" Clicked="OnCopyAssignmentsClicked" />
                </Grid>
                <HorizontalStackLayout Spacing="8">
                    <Button Text="Export Assignments" Clicked="OnExportAssignmentsClicked" />
                    <Button Text="Import Assignments" Clicked="OnImportAssignmentsClicked" />
                </HorizontalStackLayout>
                <CollectionView x:Name="AssignmentsCollection" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,3" Padding="12" HasShadow="False" BorderColor="LightGray">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" />
                                        <Label Text="{Binding DueDate, StringFormat='Due: {0:MM/dd/yyyy}'}" FontSize="13" TextColor="Gray" />
                                        <Label Text="{Binding AvailablePoints, StringFormat='{0} pts'}" FontSize="13" TextColor="Gray" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1"
                                            Text="Grade"
                                            WidthRequest="65"
                                            Margin="3,0"
                                            VerticalOptions="Center"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnGradeAssignmentClicked" />
                                    <Button Grid.Column="2"
                                            Text="Edit"
                                            WidthRequest="55"
                                            Margin="3,0"
                                            VerticalOptions="Center"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnEditAssignmentClicked" />
                                    <Button Grid.Column="3"
                                            Text="Del"
                                            WidthRequest="50"
                                            BackgroundColor="#c62828"
                                            VerticalOptions="Center"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnDeleteAssignmentClicked" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label x:Name="NoAssignmentsLabel" Text="No assignments." TextColor="Gray" IsVisible="False" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Modules (ISSUE-42) -->
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Modules" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="+ Add" WidthRequest="70" Clicked="OnAddModuleClicked" />
                </Grid>
                <CollectionView x:Name="ModulesCollection" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,3" Padding="12" HasShadow="False" BorderColor="LightGray">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" />
                                        <Label Text="{Binding ItemCount, StringFormat='{0} item(s)'}" FontSize="13" TextColor="Gray" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1"
                                            Text="Content"
                                            WidthRequest="80"
                                            Margin="4,0"
                                            VerticalOptions="Center"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnManageModuleContentClicked" />
                                    <Button Grid.Column="2"
                                            Text="Del"
                                            WidthRequest="50"
                                            BackgroundColor="#c62828"
                                            VerticalOptions="Center"
                                            CommandParameter="{Binding Id}"
                                            Clicked="OnDeleteModuleClicked" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label x:Name="NoModulesLabel" Text="No modules." TextColor="Gray" IsVisible="False" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
